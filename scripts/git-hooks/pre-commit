#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

# Block accidental .env commits
if git diff --cached --name-only | grep -qE '(^|\/)(\.env|\.env\..+)$'; then
  echo "[pre-commit] ERROR: Staging a .env file. Remove it from the index first." >&2
  echo "  git restore --staged <file>" >&2
  exit 1
fi

# Docs lint — skip gracefully if the script is absent (not all repos have it)
if [[ -f scripts/lint_docs.sh ]]; then
  echo "[pre-commit] Linting docs coverage..."
  if bash scripts/lint_docs.sh; then
    echo "[pre-commit] Docs OK"
  else
    echo "[pre-commit] Documentation issues found. Aborting commit." >&2
    exit 1
  fi
fi

# Release version check — only meaningful on release/* branches
current_branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo "")"
if [[ "$current_branch" == release/* ]] && [[ -f scripts/check_release_version.sh ]]; then
  if ! bash scripts/check_release_version.sh --version-file VERSION; then
    echo "[pre-commit] Release branch VERSION check failed." >&2
    exit 1
  fi
fi
